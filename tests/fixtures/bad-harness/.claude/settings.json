{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/missing-script.sh",
            "args": []
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/noop.sh",
            "args": [],
            "if": "true"
          }
        ]
      }
    ],
    "NotARealEvent": [
      {
        "hooks": [{ "type": "command", "command": "echo hi" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/not-executable.sh",
            "args": []
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": ["Bash(*)", "NotARealTool(foo)"]
  }
}
